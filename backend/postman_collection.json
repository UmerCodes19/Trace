{
  "info": {
    "name": "Trace API",
    "_postman_id": "trace-lost-found-api-collection",
    "description": "Complete API collection for TRACE — Cloud-Based Lost & Found System\nBahria University Karachi\n\nBase URL: https://trace-self.vercel.app/api\nLocal URL: http://localhost:5000/api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://trace-self.vercel.app/api",
      "type": "string"
    },
    {
      "key": "local_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Posts",
      "item": [
        {
          "name": "Get All Posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            },
            "description": "Retrieve all lost and found posts with pagination"
          },
          "response": []
        },
        {
          "name": "Filter Posts (Lost, Limit 10)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts?type=lost&limit=10",
              "host": ["{{base_url}}"],
              "path": ["posts"],
              "query": [
                { "key": "type", "value": "lost" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Filter posts by type=lost with limit of 10"
          },
          "response": []
        },
        {
          "name": "Filter Posts (Found)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts?type=found&limit=10",
              "host": ["{{base_url}}"],
              "path": ["posts"],
              "query": [
                { "key": "type", "value": "found" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Filter posts by type=found"
          },
          "response": []
        },
        {
          "name": "Search Posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts?search=laptop&building=LIAQUAT BLOCK",
              "host": ["{{base_url}}"],
              "path": ["posts"],
              "query": [
                { "key": "search", "value": "laptop" },
                { "key": "building", "value": "LIAQUAT BLOCK" }
              ]
            },
            "description": "Search posts by keyword and building"
          },
          "response": []
        },
        {
          "name": "Get Single Post",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/posts/0bacf743-74e9-45a7-9c8b-729697d82952",
              "host": ["{{base_url}}"],
              "path": ["posts", "0bacf743-74e9-45a7-9c8b-729697d82952"]
            },
            "description": "Get a single post by ID"
          },
          "response": []
        },
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"lost\",\n  \"title\": \"Black Laptop\",\n  \"description\": \"Lost my black Dell laptop in the library\",\n  \"location_name\": \"LIAQUAT BLOCK\",\n  \"buildingName\": \"LIAQUAT BLOCK\",\n  \"floor\": 1,\n  \"location_room\": \"Library\",\n  \"location_lat\": 24.892692,\n  \"location_lng\": 67.088686,\n  \"tags\": [\"laptop\", \"dell\", \"black\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            },
            "description": "Create a new lost or found post (requires auth token)"
          },
          "response": []
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Black Dell Laptop (Updated)\",\n  \"description\": \"Updated description — lost near cafeteria area\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts/0bacf743-74e9-45a7-9c8b-729697d82952",
              "host": ["{{base_url}}"],
              "path": ["posts", "0bacf743-74e9-45a7-9c8b-729697d82952"]
            },
            "description": "Update an existing post by ID"
          },
          "response": []
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/posts/0bacf743-74e9-45a7-9c8b-729697d82952",
              "host": ["{{base_url}}"],
              "path": ["posts", "0bacf743-74e9-45a7-9c8b-729697d82952"]
            },
            "description": "Delete a post by ID (owner or admin only)"
          },
          "response": []
        }
      ]
    },
