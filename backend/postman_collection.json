            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/claims/respond/claim-id-here",
              "host": ["{{base_url}}"],
              "path": ["claims", "respond", "claim-id-here"]
            },
            "description": "Approve or reject a claim. Status: approved or rejected"
          },
          "response": []
        },
        {
