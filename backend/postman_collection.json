              "mode": "raw",
              "raw": "{\n  \"postId\": \"0bacf743-74e9-45a7-9c8b-729697d82952\",\n  \"message\": \"This is my laptop. It has a sticker on the back.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/claims/request",
              "host": ["{{base_url}}"],
              "path": ["claims", "request"]
