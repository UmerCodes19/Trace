<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        
        <!-- Android 12+ Native Splash Screen API Override -->
        <!-- This forces the automatic white background to match your Deep Jade Branding color -->
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <!-- Uses our isolated transparent white logo to eliminate the circular background border -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
    </style>
    
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
